#!/bin/bash
# pull_personal_recordings
# -------------------------------------------------------------------------
# Pulls personal recordings from the user's GitHub fork into
# /data/personal_samples/<wake_word>/ for use during training.
#
# Accepts any common audio format (wav, mp3, flac, ogg, m4a, webm).
# All files are auto-converted to 16kHz, 16-bit PCM, mono WAV.
#
# Uses the same GITHUB_TOKEN + GITHUB_REPO env vars as github_push.sh.
# If neither is set, or no recordings are found, this is a no-op.
#
# When --wake-word is provided, looks for a matching subfolder:
#   personal_samples/<wake_word>/   (e.g. personal_samples/hey_airuh_gorn/)
# Falls back to personal_samples/ root if no subfolder exists.
# -------------------------------------------------------------------------
set -e

PROGPATH=$(realpath "$0")
PROGDIR=$(dirname "${PROGPATH}")

KNOWN_ARGS=( data-dir wake-word )
source "${PROGDIR}/shell.functions"

# Wake word from --wake-word= or first positional arg
WAKE_WORD="${WAKE_WORD:-${POSITIONAL_ARGS[0]:-}}"

if [ -z "${GITHUB_TOKEN:-}" ] || [ -z "${GITHUB_REPO:-}" ]; then
    echo "ℹ️  GitHub not configured (GITHUB_REPO/GITHUB_TOKEN not set) — skipping recording pull."
    exit 0
fi

GITHUB_BRANCH="${GITHUB_BRANCH:-main}"
RECORDINGS_PATH="${GITHUB_RECORDINGS_PATH:-personal_samples}"

# Supported audio extensions (case-insensitive matching)
AUDIO_EXTS="wav mp3 flac ogg m4a webm aac wma"

# ---------------------------------------------------------------------------
# Sanitize wake word into a folder name:
#   "hey airuh gorn" → "hey_airuh_gorn"
#   "Yo Chungus"     → "yo_chungus"
# ---------------------------------------------------------------------------
sanitize_folder_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g; s/__*/_/g; s/^_//; s/_$//'
}

# ---------------------------------------------------------------------------
# Determine which GitHub directory to pull from.
# Priority:
#   1. personal_samples/<sanitized_wake_word>/  (wake-word-specific)
#   2. personal_samples/                        (fallback — all recordings)
# ---------------------------------------------------------------------------
GITHUB_SUBDIR=""
WAKE_WORD_DIR=""

if [ -n "${WAKE_WORD}" ]; then
    WAKE_WORD_DIR=$(sanitize_folder_name "${WAKE_WORD}")
    TRY_SUBDIR="${RECORDINGS_PATH}/${WAKE_WORD_DIR}"

    echo "===== Checking for personal recordings in ${GITHUB_REPO}/${TRY_SUBDIR} ====="
    API_URL="https://api.github.com/repos/${GITHUB_REPO}/contents/${TRY_SUBDIR}?ref=${GITHUB_BRANCH}"
    RESPONSE=$(curl -sf \
        -H "Authorization: token ${GITHUB_TOKEN}" \
        -H "Accept: application/vnd.github.v3+json" \
        "${API_URL}" 2>/dev/null) && GITHUB_SUBDIR="${TRY_SUBDIR}" || {
        echo "   No '${TRY_SUBDIR}/' subfolder found — checking root ${RECORDINGS_PATH}/"
    }
fi

# Fall back to root recordings directory
if [ -z "${GITHUB_SUBDIR}" ]; then
    GITHUB_SUBDIR="${RECORDINGS_PATH}"
    echo "===== Checking for personal recordings in ${GITHUB_REPO}/${GITHUB_SUBDIR} ====="
    API_URL="https://api.github.com/repos/${GITHUB_REPO}/contents/${GITHUB_SUBDIR}?ref=${GITHUB_BRANCH}"
    RESPONSE=$(curl -sf \
        -H "Authorization: token ${GITHUB_TOKEN}" \
        -H "Accept: application/vnd.github.v3+json" \
        "${API_URL}" 2>/dev/null) || {
        echo "ℹ️  No '${GITHUB_SUBDIR}/' directory found in ${GITHUB_REPO} (branch: ${GITHUB_BRANCH}) — skipping."
        exit 0
    }
fi

# Determine local target directory
if [ -n "${WAKE_WORD_DIR}" ]; then
    TARGET_DIR="${DATA_DIR}/personal_samples/${WAKE_WORD_DIR}"
else
    TARGET_DIR="${DATA_DIR}/personal_samples"
fi

# Extract audio file download URLs via Python (available in the container)
AUDIO_URLS=$(python3 -c "
import sys, json
exts = set('${AUDIO_EXTS}'.split())
items = json.loads(sys.stdin.read())
if not isinstance(items, list):
    sys.exit(0)
for f in items:
    name = f.get('name', '')
    url = f.get('download_url', '')
    if url and '.' in name and name.rsplit('.', 1)[1].lower() in exts:
        print(url)
" <<< "${RESPONSE}" 2>/dev/null) || true

if [ -z "${AUDIO_URLS}" ]; then
    echo "ℹ️  No audio files found in ${GITHUB_REPO}/${GITHUB_SUBDIR} — skipping."
    exit 0
fi

FILE_COUNT=$(echo "${AUDIO_URLS}" | wc -l)
echo "   Found ${FILE_COUNT} recording(s) — downloading to ${TARGET_DIR}"

mkdir -p "${TARGET_DIR}"

DOWNLOADED=0
FAILED=0
while IFS= read -r url; do
    [ -z "$url" ] && continue
    filename=$(basename "$url")
    if curl -sfL \
        -H "Authorization: token ${GITHUB_TOKEN}" \
        -o "${TARGET_DIR}/${filename}" \
        "${url}" ; then
        DOWNLOADED=$((DOWNLOADED + 1))
        echo "   ✓ ${filename}"
    else
        FAILED=$((FAILED + 1))
        echo "   ✗ ${filename} (download failed)"
    fi
done <<< "${AUDIO_URLS}"

echo
if [ ${FAILED} -gt 0 ]; then
    echo "⚠️  Downloaded ${DOWNLOADED}/${FILE_COUNT} recording(s) (${FAILED} failed)"
else
    echo "✅ Downloaded ${DOWNLOADED} personal recording(s)"
fi

# ---------------------------------------------------------------------------
# Auto-convert all recordings to 16kHz, 16-bit PCM, mono WAV
# Uses the same librosa + scipy pattern as the rest of the codebase.
# ---------------------------------------------------------------------------
if [ ${DOWNLOADED} -eq 0 ]; then
    exit 0
fi

# Activate the training venv if available (needed for librosa/scipy)
if [ -f "${DATA_DIR}/.venv/bin/activate" ]; then
    # shellcheck source=/dev/null
    source "${DATA_DIR}/.venv/bin/activate"
else
    echo "⚠️  Python venv not found — skipping audio format conversion."
    echo "   Run 'setup' first, then re-run pull_personal_recordings."
    echo "   (WAV files at 16kHz/16-bit/mono will still work without conversion.)"
    exit 0
fi

echo "   Converting recordings to 16kHz 16-bit PCM mono WAV..."

python3 - "${TARGET_DIR}" <<'PYEOF'
import os, sys, glob

input_dir = sys.argv[1]
AUDIO_EXTS = ('.wav', '.mp3', '.flac', '.ogg', '.m4a', '.webm', '.aac', '.wma')

# Find audio files
files = []
for ext in AUDIO_EXTS:
    files.extend(glob.glob(os.path.join(input_dir, f'*{ext}')))
    files.extend(glob.glob(os.path.join(input_dir, f'*{ext.upper()}')))

# Deduplicate
files = sorted(set(files))
if not files:
    print("   No audio files to convert.")
    sys.exit(0)

# Lazy-import heavy libs only when we have work to do
import numpy as np
import scipy.io.wavfile
import librosa

converted = 0
failed = 0
already_ok = 0

for path in files:
    basename = os.path.splitext(os.path.basename(path))[0]
    dst = os.path.join(input_dir, basename + '.wav')

    try:
        y, _ = librosa.load(path, sr=16000, mono=True)
        if y.size == 0:
            raise ValueError("empty audio")

        x = np.clip(y, -1.0, 1.0)
        pcm = (x * 32767).astype(np.int16)
        scipy.io.wavfile.write(dst, 16000, pcm)

        # Remove original if it was a non-wav format
        if os.path.abspath(path) != os.path.abspath(dst):
            os.remove(path)
            converted += 1
            print(f"   ✓ {os.path.basename(path)} → {basename}.wav")
        else:
            converted += 1

    except Exception as e:
        failed += 1
        print(f"   ✗ {os.path.basename(path)}: {e}")

if failed > 0:
    print(f"\n⚠️  Converted {converted} file(s), {failed} failed")
else:
    print(f"\n✅ All {converted} recording(s) converted to 16kHz 16-bit PCM mono WAV")
PYEOF
